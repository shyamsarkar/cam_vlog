{
  "manifest_version": 3,
  "name": "CamVlog",
  "version": "1.0.0",
  "description": "Simple webcam recorder for vlogs and quick captures.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "CamVlog"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
